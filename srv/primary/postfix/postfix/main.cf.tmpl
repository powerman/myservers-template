compatibility_level = 3.9

myhostname = smtp.{{ .Env.MY_ORIGIN }}
myorigin = {{ .Env.MY_ORIGIN }}
mydomain = example.com
mydestination = $myhostname, {{ .Env.MY_ORIGIN }}, localhost
mynetworks = 192.168.0.0/23, 100.3.3.3, {{ .Env.MAIL_NETWORK }}

recipient_delimiter = +
home_mailbox = Maildir/

alias_database = lmdb:/etc/postfix/aliases
alias_maps = $alias_database
local_recipient_maps = $alias_maps
local_header_rewrite_clients = permit_inet_interfaces, permit_mynetworks

virtual_mailbox_domains = example.com
virtual_mailbox_base = /var/mail/vhosts
virtual_mailbox_maps = lmdb:/etc/postfix/virtual_mailbox
virtual_alias_maps = lmdb:/etc/postfix/virtual_alias
virtual_uid_maps = static:5000
virtual_gid_maps = static:5000

smtpd_sasl_auth_enable = yes
smtpd_sasl_security_options = noanonymous, noplaintext
smtpd_sasl_tls_security_options = noanonymous

# Restrict who can send mail to us.
smtpd_helo_required = yes
# Restrict who can send mail from us.
smtpd_sender_login_maps = lmdb:/etc/postfix/controlled_envelope_senders
# XXX diary.ru fails on reject_unknown_client_hostname.
smtpd_recipient_restrictions =
    permit_mynetworks
    reject_sender_login_mismatch
    permit_sasl_authenticated
    reject_unknown_client_hostname
    sleep 1, reject_unauth_pipelining
    reject_invalid_helo_hostname
    reject_non_fqdn_helo_hostname
    reject_unknown_helo_hostname
    reject_non_fqdn_sender
    reject_unknown_sender_domain
    reject_unverified_recipient
    check_policy_service inet:postgrey:10023

# DKIM, DMARC.
milter_default_action = accept
smtpd_milters =
    inet:opendkim:8891
    inet:opendmarc:8893
non_smtpd_milters = $smtpd_milters

# SRS.
sender_canonical_maps = socketmap:inet:postsrsd:10003:forward
sender_canonical_classes = envelope_sender
recipient_canonical_maps = socketmap:inet:postsrsd:10003:reverse
recipient_canonical_classes = envelope_recipient, header_recipient

# Personal preferences.
# - Receive 2bounce reports.
notify_classes = resource, software, 2bounce
# - Notify sender about emails queued for too long.
delay_warning_time = 3h
# - Increase the message size limit from 10MB to 128MB.
message_size_limit = 134217728
mailbox_size_limit = $message_size_limit
virtual_mailbox_limit = 536870912
# - Avoid needs in "|cd&&…" in ~/.forward files.
command_execution_directory = ${home}
# - Prevent attempt to enumerate local addresses.
disable_vrfy_command = yes
# - Stops mail from poorly written software.
strict_rfc821_envelopes = yes

# System preferences.
biff = no
append_dot_mydomain = yes
inet_protocols = ipv4
maillog_file = /var/log/postfix/log

smtp_tls_loglevel = 1
smtpd_tls_loglevel = 1
smtpd_tls_received_header = yes

# generated 2026-03-17, Mozilla Guideline v5.6, Postfix 3.10.8, OpenSSL 3.5.5, intermediate config
# https://ssl-config.mozilla.org/#server=postfix&version=3.10.8&config=intermediate&openssl=3.5.5&guideline=5.6
smtpd_tls_security_level = may
smtpd_tls_auth_only = yes
smtpd_tls_cert_file = /tls/caddy/certificates/acme-v02.api.letsencrypt.org-directory/smtp.{{ .Env.MY_ORIGIN }}/smtp.{{ .Env.MY_ORIGIN }}.crt
smtpd_tls_key_file = /tls/caddy/certificates/acme-v02.api.letsencrypt.org-directory/smtp.{{ .Env.MY_ORIGIN }}/smtp.{{ .Env.MY_ORIGIN }}.key
smtp_tls_security_level = may
tls_medium_cipherlist = ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384
tls_eecdh_auto_curves = X25519 prime256v1 secp384r1
tls_ffdhe_auto_groups =
