# table ip filter {
#     chain FORWARD {
#         type filter hook forward priority filter; policy drop;
#         jump DOCKER-USER
#         ... allow from/to docker's IP/interface

table ip filter {
    chain in-fwd {
    }
    chain in-fwd-anchor {
    }
}
flush chain ip filter in-fwd
flush chain ip filter in-fwd-anchor
table ip filter {
    {{template "chain.in-fwd" .}}
    {{template "chain.in-fwd-anchor" .}}

    chain DOCKER-USER {
        ct state established,related accept

        # Allow outbound SMTP only from postfix container's network (br-mail).
        # All other sources (e.g. VPN clients, other containers) are blocked
        # to prevent spam that could get the server's IP blacklisted.
        iifname "br-mail" tcp dport smtp accept
        oifname $WAN_IFNAME tcp dport smtp drop

        iifname "wg.home" accept

        ip daddr $HOME_IP jump in-fwd
        ip daddr $HOME_IP jump in-fwd-anchor
    }
}

# table ip nat {
#     chain POSTROUTING {
#         type nat hook postrouting priority srcnat; policy accept;
#         ... masquerade from docker's IP

table inet nat {
    chain postrouting-after-docker {
        type nat hook postrouting priority srcnat + 1;

        oifname $WAN_IFNAME snat ip to $WAN_IP
        # Masquerade hairpin NAT traffic so the home server routes replies back via WireGuard,
        # not via the internet (which it would do for the public source IP otherwise).
        oifname "wg.home" ip saddr $WAN_IP masquerade
    }
}
