table ip filter {
    chain DOCKER-USER {
        ct state established,related accept

        # Allow outbound SMTP only from postfix container's network (br-mail).
        # All other sources (e.g. VPN clients, other containers) are blocked
        # to prevent spam that could get the server's IP blacklisted.
        iifname "br-mail" tcp dport smtp accept
        oifname $WAN_IFNAME tcp dport smtp drop
    }
}

